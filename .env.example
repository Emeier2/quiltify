# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real secrets.

# ── HuggingFace ────────────────────────────────────────────────────────────
# Required for FLUX.1-dev (gated model).
# Get yours at https://huggingface.co/settings/tokens
# Leave blank to fall back to FLUX.1-schnell (no token needed).
HF_TOKEN=

# ── Ollama ─────────────────────────────────────────────────────────────────
# Overridden by docker-compose to http://ollama:11434 — only set here if
# you are pointing at an external Ollama server.
# OLLAMA_URL=http://localhost:11434

# Model names (must be pulled on the Ollama server before first use):
#   ollama pull qwen2.5:14b
#   ollama pull gemma3:12b
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_MODEL_GEOMETRY=qwen2.5:14b
OLLAMA_MODEL_CRITIC=gemma3:12b

# ── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# On the Azure VM set this to your VM's public IP or custom domain:
#   ALLOWED_ORIGINS=http://<VM_PUBLIC_IP>
ALLOWED_ORIGINS=http://localhost,http://localhost:80

# ── Azure Container Registry (set on VM, not committed) ────────────────────
# IMAGE_REGISTRY=<acr-name>.azurecr.io/

# ── Forge / ComfyUI (optional) ─────────────────────────────────────────────
# Only needed if you run a separate image-generation server.
# FORGE_API_URL=http://localhost:7860
